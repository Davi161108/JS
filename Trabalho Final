import React, { useState, useEffect } from 'react';
import './App.css'; // Arquivo de estilização

export default function App() {
  // --- ESTADOS (useState) ---
  const [lista, setLista] = useState([]); // Lista principal de registros
  const [inputNome, setInputNome] = useState(''); // Estado do formulário: Campo Nome
  const [inputDesc, setInputDesc] = useState(''); // Estado do formulário: Campo Descrição
  const [idEdicao, setIdEdicao] = useState(null); // Controla se estamos editando (guarda o ID) ou cadastrando (null)

  // --- PERSISTÊNCIA (useEffect + LocalStorage) ---
  
  // 1. CARREGAR DADOS: Executa UMA VEZ ao abrir o app (array de dependências vazio [])
  useEffect(() => {
    const dadosSalvos = localStorage.getItem('@meu_app_dados');
    if (dadosSalvos) {
      setLista(JSON.parse(dadosSalvos)); // Converte a string de volta para Array/Objeto
    }
  }, []);

  // 2. SALVAR DADOS: Executa AUTOMATICAMENTE sempre que a variável 'lista' mudar
  useEffect(() => {
    localStorage.setItem('@meu_app_dados', JSON.stringify(lista)); // Salva convertendo o array em String
  }, [lista]);

  // --- FUNÇÕES DO CRUD ---

  // [CADASTRO & EDIÇÃO] Salva o item (novo ou editado)
  const salvarRegistro = (e) => {
    e.preventDefault(); // Impede a página de recarregar com o envio do formulário

    if (!inputNome || !inputDesc) {
      alert("Preencha todos os campos!");
      return;
    }

    if (idEdicao !== null) {
      // --- MODO EDIÇÃO ---
      // Mapeia a lista: se for o item sendo editado, substitui pelos novos dados; senão, mantém o item antigo
      const listaAtualizada = lista.map((item) => {
        if (item.id === idEdicao) {
          return { ...item, nome: inputNome, descricao: inputDesc };
        }
        return item;
      });
      setLista(listaAtualizada);
      setIdEdicao(null); // Sai do modo edição
    } else {
      // --- MODO CADASTRO ---
      const novoItem = {
        id: Date.now().toString(), // ID único baseado no tempo
        nome: inputNome,
        descricao: inputDesc,
      };
      setLista([...lista, novoItem]); // Imutabilidade: adiciona no fim da lista
    }

    // Limpa os inputs após salvar
    limparCampos();
  };

  // Prepara a tela para edição preenchendo os inputs com o item clicado
  const iniciarEdicao = (item) => {
    setIdEdicao(item.id);
    setInputNome(item.nome);
    setInputDesc(item.descricao);
  };

  // [EXCLUSÃO] Remove o item filtrando a lista
  const excluirRegistro = (id) => {
    // Retorna uma nova lista contendo apenas os itens que possuem ID diferente do ID excluído
    const listaFiltrada = lista.filter((item) => item.id !== id);
    setLista(listaFiltrada);

    // Se o item que estava sendo editado for excluído, cancela a edição
    if (idEdicao === id) {
      setIdEdicao(null);
      limparCampos();
    }
  };

  // Reseta os campos de texto do formulário
  const limparCampos = () => {
    setInputNome('');
    setInputDesc('');
    setIdEdicao(null);
  };

  return (
    <div className="container">
      <h1>Gerenciador Web Neutro</h1>

      {/* FORMULÁRIO DE CADASTRO / EDIÇÃO */}
      <form onSubmit={salvarRegistro} className="formulario">
        <h2>{idEdicao !== null ? 'Editar Registro' : 'Novo Registro'}</h2>
        
        <input 
          type="text" 
          placeholder="Nome do Item" 
          value={inputNome} 
          onChange={(e) => setInputNome(e.target.value)} 
        />
        
        <input 
          type="text" 
          placeholder="Descrição / Atributo" 
          value={inputDesc} 
          onChange={(e) => setInputDesc(e.target.value)} 
        />

        <div className="botoes-grupo">
          <button type="submit" className="btn-salvar">
            {idEdicao !== null ? 'Atualizar' : 'Cadastrar'}
          </button>
          <button type="button" onClick={limparCampos} className="btn-limpar">Cancelar</button>
        </div>
      </form>

      {/* LISTAGEM DE DADOS */}
      <div className="listagem">
        <h2>Registros Salvos ({lista.length})</h2>
        {lista.length === 0 ? (
          <p>Nenhum registro encontrado.</p>
        ) : (
          lista.map((item) => (
            <div key={item.id} className="card">
              <h3>{item.nome}</h3>
              <p>{item.descricao}</p>
              <div className="card-botoes">
                <button onClick={() => iniciarEdicao(item)} className="btn-editar">Editar</button>
                <button onClick={() => excluirRegistro(item.id)} className="btn-excluir">Excluir</button>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );
}








App.js (MOBILE/EXPO GO)

import React, { useState, useEffect } from 'react';
import { 
  StyleSheet, 
  Text, 
  View, 
  TextInput, 
  Button, 
  FlatList, 
  TouchableOpacity, 
  Alert 
} from 'react-native';
// Importação obrigatória para persistência de dados no Mobile
import AsyncStorage from '@react-native-async-storage/async-storage';

export default function App() {
  // --- ESTADOS (useState) ---
  const [lista, setLista] = useState([]);
  const [inputNome, setInputNome] = useState('');
  const [inputDesc, setInputDesc] = useState('');
  const [idEdicao, setIdEdicao] = useState(null); // Controla se estamos editando ou cadastrando

  // --- PERSISTÊNCIA (AsyncStorage) ---
  
  // No mobile, funções de armazenamento são ASSÍNCRONAS (usam async/await)
  const carregarDadosMobile = async () => {
    try {
      const dadosSalvos = await AsyncStorage.getItem('@meu_app_dados_mobile');
      if (dadosSalvos !== null) {
        setLista(JSON.parse(dadosSalvos));
      }
    } catch (error) {
      Alert.alert("Erro", "Falha ao carregar os dados!");
    }
  };

  const salvarDadosMobile = async (novaLista) => {
    try {
      await AsyncStorage.setItem('@meu_app_dados_mobile', JSON.stringify(novaLista));
    } catch (error) {
      Alert.alert("Erro", "Falha ao salvar os dados!");
    }
  };

  // Carrega os dados assim que o aplicativo abre
  useEffect(() => {
    carregarDadosMobile();
  }, []);

  // --- FUNÇÕES DO CRUD ---

  const salvarRegistro = () => {
    if (!inputNome || !inputDesc) {
      Alert.alert("Erro", "Preencha todos os campos!");
      return;
    }

    let listaAtualizada = [];

    if (idEdicao !== null) {
      // --- MODO EDIÇÃO ---
      listaAtualizada = lista.map((item) => {
        if (item.id === idEdicao) {
          return { ...item, nome: inputNome, descricao: inputDesc };
        }
        return item;
      });
      setIdEdicao(null);
    } else {
      // --- MODO CADASTRO ---
      const novoItem = {
        id: Date.now().toString(),
        nome: inputNome,
        descricao: inputDesc,
      };
      listaAtualizada = [...lista, novoItem];
    }

    setLista(listaAtualizada);
    salvarDadosMobile(listaAtualizada); // Envia a lista atualizada para o armazenamento local
    limparCampos();
  };

  const iniciarEdicao = (item) => {
    setIdEdicao(item.id);
    setInputNome(item.nome);
    setInputDesc(item.descricao);
  };

  const excluirRegistro = (id) => {
    // Alerta de confirmação antes de deletar (Boa prática muito avaliada em Mobile!)
    Alert.alert(
      "Confirmar", 
      "Deseja realmente excluir este registro?", 
      [
        { text: "Cancelar", style: "cancel" },
        { 
          text: "Excluir", 
          onPress: () => {
            const listaFiltrada = lista.filter((item) => item.id !== id);
            setLista(listaFiltrada);
            salvarDadosMobile(listaFiltrada); // Atualiza o armazenamento local pós-exclusão
            if (idEdicao === id) limparCampos();
          },
          style: "destructive"
        }
      ]
    );
  };

  const limparCampos = () => {
    setInputNome('');
    setInputDesc('');
    setIdEdicao(null);
  };

  return (
    <View style={styles.container}>
      <Text style={styles.tituloApp}>Gerenciador Mobile Neutro</Text>

      {/* SESSÃO FORMULÁRIO */}
      <View style={styles.formulario}>
        <Text style={styles.tituloSecao}>
          {idEdicao !== null ? 'Modo: Editando Registro' : 'Modo: Novo Registro'}
        </Text>
        
        <TextInput 
          style={styles.input} 
          placeholder="Nome do Item" 
          value={inputNome} 
          onChangeText={setInputNome} 
        />
        <TextInput 
          style={styles.input} 
          placeholder="Descrição / Atributo" 
          value={inputDesc} 
          onChangeText={setInputDesc} 
        />

        <View style={styles.botoesGrupo}>
          <Button title={idEdicao !== null ? 'Atualizar' : 'Salvar'} onPress={salvarRegistro} color="green" />
          <Button title="Cancelar" onPress={limparCampos} color="gray" />
        </View>
      </View>

      <Text style={styles.tituloSecao}>Registros Salvos ({lista.length})</Text>

      {/* SESSÃO DE LISTAGEM (FlatList obrigatório) */}
      <FlatList
        data={lista}
        keyExtractor={(item) => item.id}
        renderItem={({ item }) => (
          <View style={styles.card}>
            <View style={styles.cardConteudo}>
              <Text style={styles.cardNome}>{item.nome}</Text>
              <Text style={styles.cardDesc}>{item.descricao}</Text>
            </View>
            <View style={styles.cardBotoes}>
              {/* TouchableOpacity usado para criar botões estilizados personalizados */}
              <TouchableOpacity style={styles.btnEditar} onPress={() => iniciarEdicao(item)}>
                <Text style={styles.btnTexto}>Editar</Text>
              </TouchableOpacity>
              <TouchableOpacity style={styles.btnExcluir} onPress={() => excluirRegistro(item.id)}>
                <Text style={styles.btnTexto}>Excluir</Text>
              </TouchableOpacity>
            </View>
          </View>
        )}
      />
    </View>
  );
}

